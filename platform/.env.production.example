###############################################
# Thailand Together - Production Environment
# Hostinger Cloud Hosting
#
# Copy this file to .env on the server:
#   cp .env.production.example .env
#   php artisan key:generate
###############################################

APP_NAME="Thailand Together"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://platform.pattayatogether.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

###############################################
# Database (MySQL on Hostinger)
# Create database via hPanel → Databases → MySQL
###############################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

###############################################
# Session & Cache
###############################################
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=platform.pattayatogether.com
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

###############################################
# Mail (configure with your mail provider)
###############################################
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=info@pattayatogether.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="info@pattayatogether.com"
MAIL_FROM_NAME="${APP_NAME}"

###############################################
# Vite
###############################################
VITE_APP_NAME="${APP_NAME}"
