# ─── Cluster-Specific Environment ─────────────────────────
# Copy to .env and set CLUSTER_CODE before starting

CLUSTER_CODE=new_cluster
COUNTRY_CODE=TH

APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8081
APP_PORT=8081

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3307
DB_DATABASE=new_cluster_db
DB_USERNAME=tt_user
DB_PASSWORD=tt_password
DB_ROOT_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_PREFIX=new_cluster_

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

LOG_CHANNEL=stack
LOG_LEVEL=warning
