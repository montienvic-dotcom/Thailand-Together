# ─── Thailand Together Docker Environment ─────────────────
# Copy this file to .env and adjust values for your cluster

# ─── Cluster Configuration ────────────────────────────────
CLUSTER_CODE=pattaya
COUNTRY_CODE=TH

# ─── Application ──────────────────────────────────────────
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_PORT=8080

# ─── Database ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=thailand_together
DB_USERNAME=tt_user
DB_PASSWORD=tt_password
DB_ROOT_PASSWORD=secret

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─── Queue & Cache ────────────────────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── Search ───────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey
MEILISEARCH_PORT=7700

# ─── Mail (dev: mailpit, prod: smtp) ─────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@thailandtogether.com"
MAIL_FROM_NAME="Thailand Together"
MAIL_UI_PORT=8025

# ─── Logging ──────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=warning
